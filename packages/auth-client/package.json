{
  "name": "@labf/auth-client",
  "version": "1.0.0",
  "description": "OIDC client SDK for 11plus-hub authentication",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./browser": {
      "types": "./src/browser.ts",
      "import": "./src/browser.ts"
    },
    "./test-helpers": {
      "types": "./src/test-helpers.ts",
      "import": "./src/test-helpers.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./browser": {
        "types": "./dist/browser.d.ts",
        "import": "./dist/browser.js"
      },
      "./test-helpers": {
        "types": "./dist/test-helpers.d.ts",
        "import": "./dist/test-helpers.js"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DanWangDev/writing-buddy.git",
    "directory": "packages/auth-client"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "jose": "^6.0.11"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.10.7",
    "typescript": "~5.7.3"
  },
  "peerDependencies": {
    "express": "^4.0.0"
  }
}
