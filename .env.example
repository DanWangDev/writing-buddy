# Server
NODE_ENV=development
PORT=5050

# Database
DATABASE_PATH=./packages/backend/data/writting-buddy.db

# Auth
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# AI Coach (Alibaba Cloud Model Studio / DashScope)
DASHSCOPE_API_KEY=sk-xxx
LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# Cost Controls
DAILY_SPEND_CEILING=50
FREE_TIER_DAILY_SESSIONS=3
